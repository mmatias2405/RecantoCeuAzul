# ==============================================================================
# RECANTO DO CÉU AZUL - TEMPLATE DE CONFIGURAÇÃO (.env)
# Instruções: Copie este arquivo para um novo chamado '.env' e preencha os valores.
# ==============================================================================

# --- Banco de Dados (MySQL) ---
# O usuário administrativo (ex: root)
MYSQL_USER=seu_usuario_aqui
# Uma senha forte (evite usar a mesma para diferentes serviços)
MYSQL_PASSWORD=sua_senha_segura_aqui
# O nome do schema que será criado automaticamente
MYSQL_DATABASE=nome_do_banco_de_dados
# Porta de exposição no host (Padrão: 3306)
MYSQL_PORT=3306

# --- Configurações do Broker MQTT ---
# Endereço do broker (ex: mqtt.seu-dominio.com.br ou IP local)
MQTT_URL=endereco_do_seu_broker
# Credenciais de autenticação do Mosquitto
MQTT_USERNAME=usuario_mqtt
MQTT_PASSWORD=senha_mqtt
# Identificador único da aplicação no Broker
MQTT_CLIENTID=identificador_da_api
# Tópico principal para escuta de mensagens (ex: sensores/vazao)
MQTT_TOPIC=caminho/do/topico

# --- Configuração do InfluxDB (Séries Temporais) ---
# Usuário inicial para o setup do InfluxDB 2.x
INFLUXDB_USERNAME=usuario_influx
# Senha de acesso à interface e API
INFLUXDB_PASSWORD=senha_segura_influx
# Token de autenticação gerado pelo InfluxDB (Obrigatório para a API)
INFLUXDB_TOKEN=token_gerado_pelo_influxdb
# Nome do container de dados (ex: home ou telemetria)
INFLUXDB_BUCKET=nome_do_bucket
# Nome da organização (ex: docs ou minha_casa)
INFLUXDB_ORG=nome_da_organizacao

# --- Microserviços (Portas de Acesso) ---
# Porta onde a API Spring Boot ficará disponível (Padrão: 8081)
API_PORT=8081
# Porta onde a interface Web ficará disponível (Padrão: 8080)
WEB_PORT=8080